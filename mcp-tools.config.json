{
  "tools": [
    {
      "name": "web_search",
      "description": "Search the web using free search engines (Google, Bing, DuckDuckGo, Yahoo). Returns title, URL, and snippet for each result.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The search query string"
          },
          "engine": {
            "type": "string",
            "description": "Search engine to use",
            "enum": ["google", "bing", "duckduckgo", "yahoo"],
            "default": "bing"
          },
          "limit": {
            "type": "number",
            "description": "Maximum number of results to return (1-10)",
            "default": 5,
            "minimum": 1,
            "maximum": 10
          }
        },
        "required": ["query"]
      },
      "modulePath": "./searchEngineTool.js",
      "functionName": null,
      "exportType": "default",
      "argumentOrder": [
        "query",
        "engine"
      ],
      "parameterMapping": {
        "targetFunction": {
          "query": "query",
          "engine": "engine"
        }
      },
      "resultFormatting": {
        "type": "wrapper",
        "template": {
          "query": "{{query}}",
          "engine": "{{engine}}",
          "limit": "{{limit}}",
          "count": "{{count}}",
          "results": "{{results}}"
        },
        "sliceLimit": "limit"
      }
    }
  ]
}